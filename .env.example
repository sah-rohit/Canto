
# ═══════════════════════════════════════════════════════════════════
#  Canto — API Keys Configuration
#  Copy this file to .env and fill in your API keys
#  NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# ── AI Providers ──────────────────────────────────────────────────

# Groq API Key (get from https://console.groq.com)
# Primary provider — Llama 3.1 8B Instant
GROQ_API_KEY=your_groq_key_here

# GitHub Models API Keys (get from https://github.com/marketplace/models)
# Fallback 2: DeepSeek V3
GITHUB_DEEPSEEK_KEY=your_github_pat_for_deepseek_here
# Fallback 3: Grok mini 3
GITHUB_GROK_KEY=your_github_pat_for_grok_here

# Cloudflare Workers AI — Account 1 (get from https://dash.cloudflare.com)
# Fallback 4: google/gemini-3.1-flash-lite  |  TTS: melotts-1.5-max
CF_ACCOUNT_1_ID=your_cloudflare_account_id_1_here
CF_ACCOUNT_1_TOKEN=your_cloudflare_api_token_1_here
# TTS token (can be same as CF_ACCOUNT_1_TOKEN or a separate scoped token)
CF_TTS_TOKEN=your_cloudflare_tts_token_here

# Cloudflare Workers AI — Account 2 (get from https://dash.cloudflare.com)
# Fallback 5: openai/gpt-4.1-mini
CF_ACCOUNT_2_ID=your_cloudflare_account_id_2_here
CF_ACCOUNT_2_TOKEN=your_cloudflare_api_token_2_here

# Ollama Cloud API Keys (get from https://ollama.com/cloud)
# Fallback 6: Qwen3 Next 80B
OLLAMA_DEEPSEEK_KEY=your_ollama_key_1_here
# Fallback 7: Nemotron 3 Nano 30B
OLLAMA_KIMI_KEY=your_ollama_key_2_here

# ── Knowledge Sources ────────────────────────────────────────────

# NASA API Key (get from https://api.nasa.gov)
NASA_API_KEY=your_nasa_key_here

# CORE Academic API Key (get from https://core.ac.uk/services/api)
CORE_API_KEY=your_core_api_key_here

# Wikipedia API — uses REST API (no key needed for basic access)
# WIKIPEDIA_ACCESS_TOKEN=your_wikipedia_token_here

# Internet Archive — uses Open Library API (no key needed for search)
# IA_S3_ACCESS_KEY=your_ia_access_key_here
