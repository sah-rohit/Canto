# ═══════════════════════════════════════════════════════════════════
#  Canto — API Keys Configuration
#  Copy this file to .env and fill in your API keys
#  NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# ── AI Providers ──────────────────────────────────────────────────

# Ollama Cloud API Keys (get from https://ollama.com/cloud)
# Key 1: Used for Qwen, DeepSeek, and non-Kimi models
OLLAMA_DEEPSEEK_KEY=your_ollama_key_1_here
# Key 2: Used for Kimi models
OLLAMA_KIMI_KEY=your_ollama_key_2_here

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# ── Knowledge Sources ────────────────────────────────────────────

# NASA API Key (get from https://api.nasa.gov)
NASA_API_KEY=your_nasa_key_here

# CORE Academic API Key (get from https://core.ac.uk/services/api)
CORE_API_KEY=your_core_api_key_here

# Wikipedia API — uses REST API (no key needed for basic access)
# For higher rate limits, get credentials at https://api.wikimedia.org/
# WIKIPEDIA_ACCESS_TOKEN=your_wikipedia_token_here

# Internet Archive — uses Open Library API (no key needed for search)
# For S3 access, get keys at https://archive.org/account/s3.php
# IA_S3_ACCESS_KEY=your_ia_access_key_here
# IA_S3_SECRET_KEY=your_ia_secret_key_here