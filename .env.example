# API Keys for Canto AI providers
# Copy this file to .env and fill in your API keys

# Ollama Cloud API Keys (get from https://ollama.com/cloud)
OLLAMA_DEEPSEEK_KEY=your_deepseek_key_here
OLLAMA_KIMI_KEY=your_kimi_key_here

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# Gemini API Key (for ASCII art - get from https://aistudio.google.com/app/apikey)
API_KEY=your_gemini_key_here